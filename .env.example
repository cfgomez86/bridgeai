# Database
# PostgreSQL — add ?sslmode=require in production for DORA compliance (TLS in transit)
DATABASE_URL=postgresql://bridgeai:bridgeai@localhost:5432/bridgeai

# Field-level encryption for OAuth tokens and PATs stored in source_connections
# REQUIRED for DORA compliance. Generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this key, tokens are stored unencrypted (a warning is logged on every write).
FIELD_ENCRYPTION_KEY=

# Project
PROJECT_ROOT=.
LOG_LEVEL=INFO

# Feature flags
DRY_RUN=false

# AI Provider
AI_PROVIDER=stub          # stub | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# Quality Judge (LLM-as-Judge)
AI_JUDGE_ENABLED=true
AI_JUDGE_PROVIDER=        # blank → falls back to AI_PROVIDER
AI_JUDGE_MODEL=           # blank → falls back to AI_MODEL
AI_JUDGE_SAMPLES=3        # number of judge calls per evaluation (self-consistency)
AI_JUDGE_TEMPERATURE=0.3  # >0 introduces variance so dispersion is meaningful

# Jira integration
JIRA_REQUEST_TIMEOUT_SECONDS=10
JIRA_MAX_RETRIES=3
JIRA_RETRY_DELAY_SECONDS=5
# Map English issue type names to your project's language. Leave empty for English projects.
# Example for Spanish: JIRA_ISSUE_TYPE_MAP=Story=Historia,Task=Tarea,Bug=Error
JIRA_ISSUE_TYPE_MAP=

# OAuth callback base URL (must match what you register in each OAuth App)
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Comma-separated list of allowed CORS origins.
# For local dev the defaults in code are sufficient.
# In production, set this to your actual frontend origin(s).
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
# For devtunnels: CORS_ORIGINS=https://flpmw63h-3000.uks1.devtunnels.ms
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── OAuth credentials ────────────────────────────────────────────────────────
# Register an OAuth App per provider and set credentials here.
# Callback URIs are built dynamically from the request origin.
#
# GitHub OAuth App
#   Register at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Redirect URI: http://localhost:8000/api/v1/connections/oauth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
#
# GitLab OAuth App
#   Register at: https://gitlab.com/-/user_settings/applications
#   Redirect URI: http://localhost:8000/api/v1/connections/oauth/callback/gitlab
#   Scopes: read_user, read_api
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
#
# Azure Repos OAuth App (Microsoft Entra ID)
#   Register at: portal.azure.com → Microsoft Entra ID → App registrations
#   Redirect URI: http://localhost:8000/api/v1/connections/oauth/callback/azure_devops
#   API permissions: Azure DevOps → user_impersonation (delegated)
AZURE_DEVOPS_CLIENT_ID=
AZURE_DEVOPS_CLIENT_SECRET=
#
# Jira OAuth App (Atlassian 3LO)
#   Register at: https://developer.atlassian.com/console/myapps/
#   Redirect URI: http://localhost:8000/api/v1/connections/oauth/callback/jira
#   Scopes: read:jira-work write:jira-work read:me offline_access
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
#
# Bitbucket OAuth Consumer
#   Register at: https://bitbucket.org/your-workspace/workspace/settings/api → OAuth consumers → Add consumer
#   Callback URL: http://localhost:8000/api/v1/connections/oauth/callback/bitbucket
#   Permissions: Account (Read), Repositories (Read)
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Auth0 (https://manage.auth0.com → Applications & APIs)
# Use an EU-region tenant for DORA compliance: my-tenant.eu.auth0.com
AUTH0_DOMAIN=my-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.bridgeai.com

# Azure DevOps integration (PAT-based, for ticket creation)
AZURE_DEVOPS_TOKEN=your_personal_access_token
AZURE_ORG_URL=https://dev.azure.com/your-org
AZURE_PROJECT=your-project-name
AZURE_REQUEST_TIMEOUT_SECONDS=10
AZURE_MAX_RETRIES=3
AZURE_RETRY_DELAY_SECONDS=5
