# Database
# SQLite (default):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/bridgeai

# Project
PROJECT_ROOT=.
LOG_LEVEL=INFO

# Feature flags
DRY_RUN=false

# AI Provider
AI_PROVIDER=stub          # stub | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# Jira integration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=service-account@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_REQUEST_TIMEOUT_SECONDS=10
JIRA_MAX_RETRIES=3
JIRA_RETRY_DELAY_SECONDS=5
# Map English issue type names to your project's language. Leave empty for English projects.
# Example for Spanish: JIRA_ISSUE_TYPE_MAP=Story=Historia,Task=Tarea,Bug=Error
JIRA_ISSUE_TYPE_MAP=

# Azure DevOps integration
AZURE_DEVOPS_TOKEN=your_personal_access_token
AZURE_ORG_URL=https://dev.azure.com/your-org
AZURE_PROJECT=your-project-name
AZURE_REQUEST_TIMEOUT_SECONDS=10
AZURE_MAX_RETRIES=3
AZURE_RETRY_DELAY_SECONDS=5
